{
  "name": "salesforce-mcp",
  "version": "1.1.0",
  "description": "Read-only MCP server for Salesforce API with Google OAuth and SOQL sanitization",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "deploy": "bash deploy.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsforce": "^3.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.7",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  }
}
