# Salesforce Client Credentials Auth
SF_CLIENT_ID=<Consumer Key from Connected App>
SF_CLIENT_SECRET=<Consumer Secret from Connected App>
SF_INSTANCE_URL=https://your-org--sandbox.sandbox.my.salesforce.com
SF_LOGIN_URL=https://test.salesforce.com
SF_API_VERSION=62.0

# NOTE: For sandbox orgs, SF_LOGIN_URL must be https://test.salesforce.com
# For production orgs, use https://login.salesforce.com

# HTTP mode (Cloud Run) — set these when deploying to Cloud Run
# PORT=8080
# ALLOWED_DOMAIN=example.com
# SERVER_URL=https://your-service.example.com
# GOOGLE_CLIENT_ID=<Google OAuth client ID>
# GOOGLE_CLIENT_SECRET=<Google OAuth client secret>
